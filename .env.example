# ============================================================
# OpenHands + GitLab 連携設定
# cp .env.example .env して値を埋めてください
# ============================================================

# ─── GitLab 接続設定 ──────────────────────────────────────────
#
# GitLab の URL（ローカルでも外部でも同じ変数）
#   ローカル GitLab（docker compose --profile local で起動）の場合:
#     GITLAB_EXTERNAL_URL=http://localhost:8080
#   外部 GitLab の場合:
#     GITLAB_EXTERNAL_URL=http://192.168.1.10:8080
#
# GITLAB_TOKEN は setup.sh 実行前に手動で設定してください。
#   1. GitLab に openhands ユーザーでログイン
#   2. User Settings → Access Tokens → PAT を作成
#      スコープ: api, read_repository, write_repository
#   3. 発行されたトークンを GITLAB_TOKEN に設定
# ─────────────────────────────────────────────────────────────
GITLAB_EXTERNAL_URL=http://localhost:8080
GITLAB_TOKEN=

# ─── Webhook URL ──────────────────────────────────────────────
#
# GitLab から Webhook Receiver に到達できる URL
#
#   ローカル GitLab（同一 Docker ネットワーク）の場合:
#     未設定のままで OK（デフォルト: http://openhands-webhook:5000/webhook）
#
#   外部 GitLab（別ホスト）の場合:
#     WEBHOOK_URL=http://<このホストのIP>:<WEBHOOK_PORT>/webhook
#     例: WEBHOOK_URL=http://192.168.1.20:5000/webhook
# ─────────────────────────────────────────────────────────────
WEBHOOK_URL=

# ─── LLM 接続設定 ─────────────────────────────────────────────
#
# パターン A: OpenAI 直接接続
#   LLM_API_KEY=sk-...
#   LLM_MODEL=openai/gpt-4.1
#   LLM_BASE_URL=  ← 空のまま
#
# パターン B: LiteLLM proxy (OpenAI 互換 API) 経由
#   LLM_API_KEY=<LiteLLM の API キー>
#   LLM_MODEL=openai/gpt-4.1
#   LLM_BASE_URL=http://<host>:4000
# ─────────────────────────────────────────────────────────────
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=openai/gpt-4.1
LLM_BASE_URL=

# ─── GitLab 共通設定 ──────────────────────────────────────────
# GitLab rootユーザーの初期パスワード（ローカルモード時のみ使用）
GITLAB_ROOT_PASSWORD=Password1234!

# グループ名（このグループ配下の全プロジェクトにWebhookが適用される）
GITLAB_GROUP=openhands

# OpenHands 専用ユーザー設定（MR作成者として表示される）
OPENHANDS_USER=openhands
OPENHANDS_USER_EMAIL=openhands@localhost.local
# 未設定の場合は GITLAB_ROOT_PASSWORD と同じパスワードが使われる（ローカルモード時）
OPENHANDS_USER_PASSWORD=

# ─── Webhook ─────────────────────────────────────────────────
# GitLab Webhook のシークレットトークン（任意の文字列、推奨）
WEBHOOK_SECRET=change-me-to-random-string

# ─── Resolver 動作設定 ────────────────────────────────────────
# Resolver の最大反復回数（デフォルト30）
# 複雑な Issue では増やすと成功率が上がる（増やすほどトークン消費が増える）
MAX_ITERATIONS=100

# ─── トリガー設定 ──────────────────────────────────────────────
TRIGGER_LABEL=openhands
TRIGGER_MENTION=@openhands

# ─── ポート設定（ローカルモード時） ───────────────────────────
# 他のサービスと競合する場合に変更してください
GITLAB_HTTP_PORT=8080
GITLAB_SSH_PORT=2222
OPENHANDS_PORT=3000
WEBHOOK_PORT=5000

# ─── Docker ホストアドレス（setup.sh が自動設定） ──────────────
# Mac  → host.docker.internal
# Linux → Docker bridge gateway IP（例: 172.17.0.1）
DOCKER_HOST_INTERNAL=

# ─── GitLab SSL プロキシ（setup.sh が自動設定） ───────────────
# GitLab が HTTP の場合に nginx SSL プロキシ経由で HTTPS に変換する
#
# ローカル GitLab:     GITLAB_UPSTREAM_URL=http://gitlab:80
# 外部 HTTP GitLab:   GITLAB_UPSTREAM_URL=http://<GitLabホスト>:<ポート>
# 外部 HTTPS GitLab:  設定不要（空のまま）
GITLAB_UPSTREAM_URL=

# ─── SSL 証明書（setup.sh が自動設定） ────────────────────────
# HTTP GitLab 使用時: /tmp/openhands-gitlab-ssl/server.crt
# 外部 HTTPS GitLab:   空のまま
# Resolver コンテナがこの証明書を使って gitlab-ssl-proxy を信頼する
GITLAB_SSL_CERT=
